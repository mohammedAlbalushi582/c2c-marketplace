# Production environment — copy to `.env` on the server and fill in real values.
#   cp .env.prod.example .env
# Generate strong secrets with:  openssl rand -hex 32

# ---- Public origin (your HTTPS domain, no trailing slash) ----
PUBLIC_BASE_URL=https://your-domain.com

# ---- Main app database ----
POSTGRES_USER=alamjad
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=alamjad
POSTGRES_PORT=5432

# ---- Backend JWT secrets (MUST change) ----
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32

# ---- Payments ----
# Leave as "stub" to run without a gateway (fees are simulated). To take real
# payments, set "thawani" and fill the keys from your Thawani merchant account.
PAYMENT_PROVIDER=stub
THAWANI_BASE_URL=https://checkout.thawani.om/api/v1
THAWANI_SECRET_KEY=
THAWANI_PUBLISHABLE_KEY=
