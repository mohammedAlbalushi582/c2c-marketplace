# Copy to .env and adjust. Used by docker-compose and the Go backend (godotenv).

# ---- Postgres (main app DB) ----
POSTGRES_USER=alamjad
POSTGRES_PASSWORD=alamjad_dev_pw
POSTGRES_DB=alamjad
POSTGRES_PORT=5432

# ---- Backend ----
APP_ENV=development
HTTP_PORT=8080
DATABASE_URL=postgres://alamjad:alamjad_dev_pw@localhost:5432/alamjad?sslmode=disable
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
CORS_ALLOWED_ORIGINS=http://localhost:3000
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:8080

# ---- Payments (listing fees) ----
# Where the browser is sent for checkout / return.
FRONTEND_BASE_URL=http://localhost:3000
# "stub" simulates payments for dev/demo; "thawani" enables Thawani Pay (needs keys).
PAYMENT_PROVIDER=stub
THAWANI_BASE_URL=https://uatcheckout.thawani.om/api/v1
THAWANI_SECRET_KEY=
THAWANI_PUBLISHABLE_KEY=
